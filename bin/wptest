#!/usr/bin/env php
<?php
/**
 * WordPress Test Suite Installer
 *
 * Sets up the WordPress testing environment by downloading WordPress core,
 * installing the PHPUnit test suite, and optionally creating a test database.
 *
 * Usage: php install-wp-tests.php [db-name] [db-user] [db-pass] [db-host] [wp-version] [skip-db-create]
 */

declare(strict_types=1);

class WordPressTestInstaller
{
    private string $dbName;
    private string $dbUser;
    private string $dbPass;
    private string $dbHost;
    private string $wpVersion;
    private bool $skipDbCreate;
    private string $tmpDir;
    private string $wpTestsDir;
    private string $wpCoreDir;
    private string $wpTestsTag;

    public function __construct(array $args)
    {
        $this->dbName = $args[1] ?? 'wordpress_testdb';
        $this->dbUser = $args[2] ?? 'root';
        $this->dbPass = $args[3] ?? 'password';
        $this->dbHost = $args[4] ?? 'localhost';
        $this->wpVersion = $args[5] ?? 'latest';
        $this->skipDbCreate = filter_var($args[6] ?? 'true', FILTER_VALIDATE_BOOLEAN);

        $this->tmpDir = rtrim(sys_get_temp_dir(), '/');
        $this->wpTestsDir = getenv('WP_TESTS_DIR') ?: "{$this->tmpDir}/wordpress-tests-lib";
        $this->wpCoreDir = getenv('WP_CORE_DIR') ?: "{$this->tmpDir}/wordpress/";

        $this->wpTestsTag = $this->resolveTestsTag();
    }

    public function run(): void
    {
        $this->printHeader();
        $this->installWordPress();
        $this->installTestSuite();
        $this->installDatabase();
        $this->printSuccess();
    }

    private function printHeader(): void
    {
        $this->log("WordPress Test Suite Installer");
        $this->log(str_repeat("=", 50));
        $this->log("Configuration:");
        $this->log("  Database Name: {$this->dbName}");
        $this->log("  Database User: {$this->dbUser}");
        $this->log("  Database Host: {$this->dbHost}");
        $this->log("  WP Version:    {$this->wpVersion}");
        $this->log("  Tests Tag:     {$this->wpTestsTag}");
        $this->log("  Skip DB:       " . ($this->skipDbCreate ? 'Yes' : 'No'));
        $this->log(str_repeat("=", 50));
    }

    private function resolveTestsTag(): string
    {
        $version = $this->wpVersion;

        if (preg_match('/^\d+\.\d+$/', $version)) {
            return "branches/{$version}";
        }

        if (preg_match('/^(\d+\.\d+)\.0$/', $version, $matches)) {
            return "tags/{$matches[1]}";
        }

        if (preg_match('/^\d+\.\d+\.\d+$/', $version)) {
            return "tags/{$version}";
        }

        if (in_array($version, ['nightly', 'trunk'], true)) {
            return 'trunk';
        }

        $latestVersion = $this->fetchLatestVersion();
        if ($latestVersion === null) {
            $this->error("Could not determine latest WordPress version");
        }

        return "tags/{$latestVersion}";
    }

    private function fetchLatestVersion(): ?string
    {
        $json = $this->download('http://api.wordpress.org/core/version-check/1.7/');
        if ($json === null) {
            return null;
        }

        $data = json_decode($json, true);
        return $data['offers'][0]['version'] ?? null;
    }

    private function installWordPress(): void
    {
        $this->log("\n[1/3] Installing WordPress Core...");

        if (is_dir($this->wpCoreDir) && file_exists("{$this->wpCoreDir}/wp-settings.php")) {
            $this->log("  ✓ WordPress already installed at {$this->wpCoreDir}");
            return;
        }

        @mkdir($this->wpCoreDir, 0755, true);

        if (in_array($this->wpVersion, ['nightly', 'trunk'], true)) {
            $this->installNightlyBuild();
        } else {
            $this->installStableBuild();
        }

        $this->installMysqliDropIn();
        $this->log("  ✓ WordPress installed successfully");
    }

    private function installNightlyBuild(): void
    {
        $this->log("  Downloading nightly build...");
        $nightlyDir = "{$this->tmpDir}/wordpress-nightly";
        $zipFile = "{$nightlyDir}/wordpress-nightly.zip";

        @mkdir($nightlyDir, 0755, true);

        $this->downloadToFile(
            'https://wordpress.org/nightly-builds/wordpress-latest.zip',
            $zipFile
        );

        $this->extractZip($zipFile, $nightlyDir);
        $this->moveDirectory("{$nightlyDir}/wordpress", $this->wpCoreDir);
    }

    private function installStableBuild(): void
    {
        $archiveName = $this->resolveArchiveName();
        $this->log("  Downloading {$archiveName}...");

        $tarFile = "{$this->tmpDir}/wordpress.tar.gz";

        $this->downloadToFile(
            "https://wordpress.org/{$archiveName}.tar.gz",
            $tarFile
        );

        $this->extractTarGz($tarFile, $this->wpCoreDir);
    }

    private function resolveArchiveName(): string
    {
        if ($this->wpVersion === 'latest') {
            return 'latest';
        }

        if (!preg_match('/^\d+\.\d+/', $this->wpVersion)) {
            return "wordpress-{$this->wpVersion}";
        }

        $json = $this->download('https://api.wordpress.org/core/version-check/1.7/');
        if ($json === null) {
            return "wordpress-{$this->wpVersion}";
        }

        if (preg_match('/^(\d+\.\d+)\.0$/', $this->wpVersion, $matches)) {
            return "wordpress-{$matches[1]}";
        }

        $data = json_decode($json, true);
        $pattern = '/^' . preg_quote($this->wpVersion, '/') . '/';

        foreach ($data['offers'] ?? [] as $offer) {
            if (preg_match($pattern, $offer['version'] ?? '')) {
                return "wordpress-{$offer['version']}";
            }
        }

        return "wordpress-{$this->wpVersion}";
    }

    private function installMysqliDropIn(): void
    {
        $dbFile = "{$this->wpCoreDir}/wp-content/db.php";
        $this->downloadToFile(
            'https://raw.github.com/markoheijnen/wp-mysqli/master/db.php',
            $dbFile
        );
    }

    private function installTestSuite(): void
    {
        $this->log("\n[2/3] Installing Test Suite...");

        if (!is_dir($this->wpTestsDir)) {
            @mkdir($this->wpTestsDir, 0755, true);

            $this->log("  Checking out test includes...");
            $this->svnCheckout(
                "https://develop.svn.wordpress.org/{$this->wpTestsTag}/tests/phpunit/includes/",
                "{$this->wpTestsDir}/includes"
            );

            $this->log("  Checking out test data...");
            $this->svnCheckout(
                "https://develop.svn.wordpress.org/{$this->wpTestsTag}/tests/phpunit/data/",
                "{$this->wpTestsDir}/data"
            );
        } else {
            $this->log("  ✓ Test suite already installed");
        }

        $this->configureTestSuite();
        $this->log("  ✓ Test suite configured");
    }

    private function configureTestSuite(): void
    {
        $configFile = "{$this->wpTestsDir}/wp-tests-config.php";

        if (file_exists($configFile)) {
            return;
        }

        $this->downloadToFile(
            "https://develop.svn.wordpress.org/{$this->wpTestsTag}/wp-tests-config-sample.php",
            $configFile
        );

        $wpCoreDir = rtrim($this->wpCoreDir, '/');

        $replacements = [
            "dirname( __FILE__ ) . '/src/'" => "'{$wpCoreDir}/'",
            'youremptytestdbnamehere' => $this->dbName,
            'yourusernamehere' => $this->dbUser,
            'yourpasswordhere' => $this->dbPass,
            'localhost' => $this->dbHost,
        ];

        $content = file_get_contents($configFile);
        foreach ($replacements as $search => $replace) {
            $content = str_replace($search, $replace, $content);
        }
        file_put_contents($configFile, $content);
    }

    private function installDatabase(): void
    {
        $this->log("\n[3/3] Setting Up Database...");

        if ($this->skipDbCreate) {
            $this->log("  ⊘ Skipping database creation (SKIP_DB_CREATE=true)");
            return;
        }

        $hostParts = explode(':', $this->dbHost);
        $hostname = $hostParts[0];
        $portOrSocket = $hostParts[1] ?? null;

        $command = "mysqladmin create {$this->dbName} --user=" . escapeshellarg($this->dbUser);

        if (!empty($this->dbPass)) {
            $command .= " --password=" . escapeshellarg($this->dbPass);
        }

        if (!empty($hostname)) {
            if ($portOrSocket !== null && ctype_digit($portOrSocket)) {
                $command .= " --host={$hostname} --port={$portOrSocket} --protocol=tcp";
            } elseif ($portOrSocket !== null) {
                $command .= " --socket={$portOrSocket}";
            } else {
                $command .= " --host={$hostname} --protocol=tcp";
            }
        }

        $this->execute($command);
        $this->log("  ✓ Database '{$this->dbName}' created");
    }

    private function download(string $url): ?string
    {
        $context = stream_context_create([
            'http' => [
                'timeout' => 30,
                'user_agent' => 'WordPress Test Suite Installer',
            ],
        ]);

        $content = @file_get_contents($url, false, $context);
        return $content !== false ? $content : null;
    }

    private function downloadToFile(string $url, string $destination): void
    {
        $content = $this->download($url);
        if ($content === null) {
            $this->error("Failed to download: {$url}");
        }

        $dir = dirname($destination);
        if (!is_dir($dir)) {
            @mkdir($dir, 0755, true);
        }

        if (file_put_contents($destination, $content) === false) {
            $this->error("Failed to write file: {$destination}");
        }
    }

    private function extractZip(string $zipFile, string $destination): void
    {
        $zip = new ZipArchive();
        if ($zip->open($zipFile) !== true) {
            $this->error("Failed to open zip file: {$zipFile}");
        }

        $zip->extractTo($destination);
        $zip->close();
    }

    private function extractTarGz(string $tarFile, string $destination): void
    {
        $command = sprintf(
            'tar --strip-components=1 -zxmf %s -C %s',
            escapeshellarg($tarFile),
            escapeshellarg($destination)
        );
        $this->execute($command);
    }

    private function moveDirectory(string $source, string $destination): void
    {
        $iterator = new RecursiveIteratorIterator(
            new RecursiveDirectoryIterator($source, RecursiveDirectoryIterator::SKIP_DOTS),
            RecursiveIteratorIterator::SELF_FIRST
        );

        foreach ($iterator as $item) {
            $target = $destination . '/' . $iterator->getSubPathname();
            if ($item->isDir()) {
                @mkdir($target, 0755, true);
            } else {
                @copy($item->getPathname(), $target);
            }
        }
    }

    private function svnCheckout(string $url, string $destination): void
    {
        $command = sprintf(
            'svn co --quiet %s %s',
            escapeshellarg($url),
            escapeshellarg($destination)
        );
        $this->execute($command);
    }

    private function execute(string $command): void
    {
        $output = [];
        $returnCode = 0;
        exec($command . ' 2>&1', $output, $returnCode);

        if ($returnCode !== 0) {
            $this->error("Command failed: {$command}\n" . implode("\n", $output));
        }
    }

    private function log(string $message): void
    {
        echo $message . PHP_EOL;
    }

    private function error(string $message): never
    {
        fwrite(STDERR, "\n✗ Error: {$message}\n");
        exit(1);
    }

    private function printSuccess(): void
    {
        $this->log("\n" . str_repeat("=", 50));
        $this->log("✓ Installation Complete!");
        $this->log(str_repeat("=", 50));
        $this->log("\nPaths:");
        $this->log("  WordPress Core: {$this->wpCoreDir}");
        $this->log("  Test Suite:     {$this->wpTestsDir}");
        $this->log("\nYou can now run your PHPUnit tests.");
    }
}

// Run the installer
$installer = new WordPressTestInstaller($argv);
$installer->run();
