{
    "name": "devuri/sim-site-maintenance",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-only",
    "description": "Puts the site in maintenance mode for all non-logged-in users.",
    "require": {
        "php": "^7.4 || ^8.0 || ^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "devuri/zipit": "^0.2.7",
        "ergebnis/composer-normalize": "^2.42",
        "fakerphp/faker": "^1.23",
        "johnpbloch/wordpress-core": "^6.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.8",
        "symfony/var-dumper": "^5.4",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "SimSiteMaintenance\\": "src/SimSiteMaintenance/"
        },
        "files": [
            "src/SimSiteMaintenance/inc/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "SimSiteMaintenance\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": [
            "composer install",
            "@test",
            "@lint",
            "bin/gdep",
            "composer install --no-dev",
            "bin/zipit copy",
            "bin/zipit"
        ],
        "codefix": [
            "@php-cs-fixer"
        ],
        "php-cs-fixer": [
            "composer require --dev friendsofphp/php-cs-fixer 3.23.0",
            "vendor/bin/php-cs-fixer fix -vvv",
            "composer remove --dev friendsofphp/php-cs-fixer"
        ],
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs",
        "lint": [
            "@php-compat",
            "@phpstan"
        ],
        "php-compat": "phpcs sim-site-maintenance.php src/ --standard=PHPCompatibilityWP --extensions=php --runtime-set testVersion 7.4-",
        "test:unit": "phpunit -c phpunit.xml --testdox",
        "test:integration": "phpunit -c phpunit-integration.xml --testdox",
        "test": "@test:unit",
        "test-covers": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit -c phpunit.xml --coverage-html coverage-report"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
